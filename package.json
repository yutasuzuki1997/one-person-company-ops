{
  "name": "one-person-company-ops",
  "version": "1.1.0",
  "description": "Multi-agent dashboard — Anthropic API or tmux + Claude Code",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "bash dashboard.sh",
    "server": "node server.js",
    "dev": "vite --config vite.config.js",
    "build": "vite build --config vite.config.js",
    "desktop": "npm run build && electron .",
    "desktop:dev": "concurrently \"npm run dev\" \"NODE_ENV=development electron .\"",
    "generate-icon": "node scripts/generate-icon.js && bash scripts/create-icns.sh",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "pack:mac": "electron-builder --mac",
    "pack:win": "electron-builder --win",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@octokit/rest": "^21.1.1",
    "electron-updater": "^6.3.9",
    "express": "^5.2.1",
    "multer": "^1.4.5-lts.1",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "canvas": "^3.2.3",
    "concurrently": "^9.1.2",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "vite": "^6.2.4"
  },
  "build": {
    "appId": "com.onecompanyops.app",
    "productName": "OneCompanyOps",
    "mac": {
      "icon": "assets/icons/icon.icns",
      "category": "public.app-category.productivity",
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "dmg": {
        "title": "OneCompanyOps",
        "backgroundColor": "#0d0d1f"
      }
    },
    "win": {
      "icon": "assets/icons/icon.png",
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "files": [
      "public_new/**/*",
      "electron/**/*",
      "lib/**/*",
      "core/**/*",
      "skills/**/*",
      "server.js",
      "package.json",
      "node_modules/**/*"
    ],
    "extraResources": [
      { "from": "core/", "to": "core/" },
      { "from": "skills/", "to": "skills/" }
    ],
    "asar": true,
    "asarUnpack": ["node_modules/node-pty/**"],
    "publish": {
      "provider": "github",
      "owner": "yutasuzuki1997",
      "repo": "one-person-company-ops"
    }
  }
}
