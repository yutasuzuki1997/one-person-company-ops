{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "cd ~/one-person-company-ops-yuta && npm run build 2>&1 | grep -E '^.*error' | head -5 || true"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(npm run build*)",
      "Bash(npm run desktop*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(node scripts/*)",
      "Bash(lsof*)",
      "Bash(curl*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(sudo rm*)"
    ]
  }
}
